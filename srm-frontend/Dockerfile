# Використовуємо легкий образ Node.js
FROM node:20-alpine

# Встановлюємо робочу директорію
WORKDIR /app

# Копіюємо файли залежностей
COPY package*.json ./

# Встановлюємо залежності
RUN npm install

# Копіюємо весь інший код
COPY . .

# Відкриваємо порт 3000
EXPOSE 3000

# Запускаємо сервер розробки
CMD ["npm", "run", "dev"]